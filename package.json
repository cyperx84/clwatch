{
  "name": "cliwatch",
  "version": "0.1.0",
  "description": "CLI tool for tracking AI coding tool changes from changelogs.info",
  "type": "module",
  "bin": {
    "cliwatch": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "sync-data": "bash scripts/sync-data.sh",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "changelog",
    "ai-tools",
    "developer-tools"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "date-fns": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.19",
    "tsup": "^8.0.2",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  }
}